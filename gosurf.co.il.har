          "cookies": [],
          "content": {
            "size": 8082,
            "mimeType": "application/javascript",
            "text": "//===========================================================\nvar _general_error = \"אופס, את זה לא חזינו...<BR>נראה שקרתה תקלה ובקשתך לא הושלמה. אפשר לנסות שוב, במידה והתקלה לא מסתדרת אנא פנו אלינו ונסייע בפתרון.\";\nvar _b2b_ads_already_viewed = [];\nvar _b2b_ads_already_clicked = [];\n\n//===========================================================\nfunction _________INIT________() { }\n\n$(document).ready(function () {\n\n        Init_UI();\n});\n\n//===========================================================\nfunction Init_UI() {\n\n    $(\".day_jumpto\").off();\n    $(\".day_jumpto\").on('click', function () {\n        $([document.documentElement, document.body]).animate({\n            scrollTop: $(\"#day_\" + $(this).attr(\"data-day\")).offset().top - 25\n        }, 400);\n    });\n\n    if (!location.pathname.includes('weather')) {\n        Chart_UI_Optimize();\n        setTimeout(function () {\n            Chart_UI_Optimize();\n        }, 10);\n    }\n\n    // B2B Ads\n    const observer = new IntersectionObserver(entries => {\n        entries.forEach(entry => {\n          if (entry.isIntersecting) {\n            // console.log('b2b_ad in view:', entry.target);\n            var adid = entry.target.getAttribute('data-ad-id');\n            B2B_Ads_View(adid);\n          }\n        });\n      });\n      \n      document.querySelectorAll('.b2b_ad').forEach(el => {\n        observer.observe(el);\n      });\n\n    // B2B Ads onclick event\n    $(document).on('click', '.b2b_ad', function () {\n        var adid = $(this).attr('data-ad-id');\n        B2B_Ads_Click(adid);\n    });\n}\n\nfunction B2B_Ads_View( adid ) {\n    if (_b2b_ads_already_viewed.includes(adid)) {\n        return;\n    }\n\n    console.log('b2b_ads_view:', adid);\n    if (navigator.sendBeacon) {\n        // navigator.sendBeacon('/ads/imp.php', JSON.stringify({ ad_id: adid }));\n        navigator.sendBeacon('/api?cmd=ad_imp&adid=' + adid, JSON.stringify({ ad_id: adid }));\n      } else {\n        fetch('/api?cmd=ad_imp&adid=' + adid, { keepalive: true });\n      }\n\n    _b2b_ads_already_viewed.push(adid);\n}\n\nfunction B2B_Ads_Click( adid ) {\n    if (_b2b_ads_already_clicked.includes(adid)) {\n        return;\n    }\n    \n    console.log('b2b_ads_click:', adid);\n    if (navigator.sendBeacon) {\n        navigator.sendBeacon('/api?cmd=ad_clk&adid=' + adid, JSON.stringify({ ad_id: adid }));\n      } else {\n        fetch('/api?cmd=ad_clk&adid=' + adid, { keepalive: true });\n      }\n\n    _b2b_ads_already_clicked.push(adid);\n}\n\n//===========================================================\nfunction getMobileOperatingSystem() {\n    var userAgent = navigator.userAgent || navigator.vendor || window.opera;\n\n    // Windows Phone must come first because its UA also contains \"Android\"\n    if (/windows phone/i.test(userAgent)) {\n        return \"Windows Phone\";\n    }\n\n    if (/android/i.test(userAgent)) {\n        return \"Android\";\n    }\n\n    // iOS detection from: http://stackoverflow.com/a/9039885/177710\n    if (/iPad|iPhone|iPod/.test(userAgent) && !window.MSStream) {\n        return \"iOS\";\n    }\n\n    return \"unknown\";\n}\n\n\n//===========================================================\nfunction _________MISC________() { }\n\n//===========================================================\nfunction JumpToDay(selector) {\n    $([document.documentElement, document.body]).animate({\n        scrollTop: $(selector).offset().top - 90\n    }, 400);\n}\n\n\n//===========================================================\nfunction GoToTop() {\n    $([document.documentElement, document.body]).animate({\n        scrollTop: 0\n    }, 400);\n}\n\n//===========================================================\nfunction HowItWorks() {\n    $([document.documentElement, document.body]).animate({\n        scrollTop: $('#how_it_works').offset().top - 70\n    }, 400);\n}\n\n//==============================================================================================================================\nfunction Validate_Highlight(obj, text) {\n    obj.focus();\n    obj.tooltipster('enable');\n    obj.tooltipster('content', text);\n    obj.tooltipster('show');\n}\n\n//===========================================================\nfunction msgbox(str, opt_deadend, opt_nologo) {\n    // console.log(str);\n\n    $('#msgbox_content').html(str);\n    $('#screen_msgbox').show();\n\n    if (opt_deadend == \"deadend\") {\n        screen_msgbox.onclick = function () {\n        };\n    }\n    else\n        if (opt_deadend) {\n            screen_msgbox.onclick = function () {\n                $('#screen_msgbox').hide();\n                Init_App_User( function () {\n                    Now_Get();\n                });\n            };\n        }\n\n    if (opt_nologo) {\n        $('#msgbox_logo').hide();\n    } else {\n        $('#msgbox_logo').show();\n    }\n}\n\n//==============================================================================================================================\nfunction Validate(form_selector) {\n    $('.tooltip').tooltipster({\n        animation: 'fade',\n        delay: 200,\n        touchDevices: true,\n        repositionOnScroll: true,\n        timer: 1000,\n        trigger: 'custom'\n    });\n\n    var elements = $(form_selector).find('.validate');\n\n    for (x = 0; x < elements.length; x++) {\n        var obj = elements.eq(x);\n        var value = obj.val();\n        var caption = obj.attr('data-caption') * 1;\n        var min_len = obj.attr('data-min-len') * 1;\n        var max_len = obj.attr('data-max-len') * 1;\n        var type = obj.attr('data-type');\n\n        if (value == '' && obj.attr('data-optional') != \"1\") {\n            Validate_Highlight(obj, 'שדה חובה');\n            return false;\n        }\n\n        if (value.length < min_len) {\n            Validate_Highlight(obj, min_len + ' אותיות לפחות');\n            return false;\n        }\n\n        if (value.length > max_len) {\n            Validate_Highlight(obj, max_len + ' אותיות לכל היותר');\n            return false;\n        }\n\n        if (type == 'email' && (/^.+@.+\\..+$/.test(value) == false)) {\n            Validate_Highlight(obj, 'זה לא נראה כמו כתובת אימייל תקינה');\n            return false;\n        }\n    }\n\n    return true;\n}\n\nfunction Forecast_Expand() {\n    // ...\n}\n\n//===========================================================\nfunction setCookie(key, val, days, level) {\n    // Ensure val is a JSON string\n    var value = typeof val === \"string\" ? val : JSON.stringify(val);\n\n    // Default at 365 days.\n    days = days || 365;\n\n    var date = new Date();\n    date.setTime(+date + (days * 86400000)); // 24 * 60 * 60 * 1000\n\n    var cookieStr = key + \"=\" + encodeURIComponent(value) + \"; expires=\" + date.toGMTString() + \"; path=/\";\n    // Handle \"level\" (domain/scope) if needed in the future\n    // Example: if (level === 'root') ... or set domain=.domain.com\n\n    window.document.cookie = cookieStr;\n\n    return value;\n}\n\n//===========================================================\nfunction getCookie(key) {\n    const match = document.cookie.match('(^|;)\\\\s*' + encodeURIComponent(key) + '\\\\s*=\\\\s*([^;]+)');\n    if (!match) return null;\n    return decodeURIComponent(match[2]);\n}\n\n\n//===========================================================\nfunction Chart_UI_Optimize() {\n    var _wave_desc_width = 200;\n    chart_obj = $('.chart:visible').eq(0);\n    tds = chart_obj.find('tr').eq(0).find('td');\n    if ($(\".is_hp\").length == 0) {\n        // _wave_desc_width = chart_obj.width() - (tds.eq(0).width() + tds.eq(1).width() + tds.eq(2).width() + tds.eq(4).width() + tds.eq(5).width()  );\n        // _wave_desc_width = chart_obj.width() - (tds.eq(0).width() + tds.eq(1).width() + tds.eq(2).width() + tds.eq(4).width() + tds.eq(5).width());\n        _wave_desc_width = chart_obj.width() - (tds.eq(0).width() + tds.eq(1).width() + tds.eq(2).width() + tds.eq(4).width() );\n    } else\n        _wave_desc_width = chart_obj.width() - (tds.eq(0).width() + tds.eq(1).width() + tds.eq(3).width());\n    $(\".wave_height_desc\").css({ \"min-width\": _wave_desc_width });\n}\n\n"

th: 100%;\n  color: #000;\n  font-size: 16px;\n}\n\n.tide_what {\n  padding-left: 7px;\n  font-size: 12px;\n  color: #888;\n}\n\n.tide_height {\n  font-size: 11px;\n  color: #888;\n  width: 100%;\n\n}\n\n.hour_good_wave {\n  /* font-weight: 400;\n  color: #0c82c3; */\n}\n\n\n.hour_very_good_wave {\n  background: #fffff7;\n  color: #0c82c3;\n}\n\n.daylight_inner {\n  padding: 10px;\n  border-radius: 10px;\n  background: #fdfcf7;\n}\n\n.daylight_unit {\n  width: 25%;\n  padding: 10px;\n}\n\n.daylight_title {\n  width: 100%;\n  font-size: 12px;\n  color: #888;\n}\n\n.daylight_value {\n  color: #333;\n  width: 100%;\n  margin-top: 0px;\n  _color: #0b4c92;\n  font-size: 16px;\n\n}\n\n.daylight_icon {\n  width: 85px;\n}\n\n\n\n.article_cover {\n  position: relative;\n  width: 100%;\n  height: 300px;\n  max-height: 300px;\n  overflow: hidden;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.article_cover img {\n  width: 100%;\n  min-height: 300px;\n  height: auto;\n  object-fit: cover;\n  object-position: center center;\n  display: block;\n  transition: transform 0.1s ease-out;\n  will-change: transform;\n  backface-visibility: hidden;\n  -webkit-backface-visibility: hidden;\n  transform: translateZ(0);\n  -webkit-transform: translateZ(0);\n}\n\n.article_title {\n  padding: 0 25px;\n  position: relative;\n  background: #fff;\n  margin-top: -50px;\n  z-index: 2;\n  padding-top: 20px;\n}\n\n.article_title h1 {\n  font-size: 32px;\n  font-weight: bold;\n  color: #333;\n  margin-top: 20px;\n}\n\n.article_body {\n  padding: 0 25px;\n  font-size: 16px;\n  position: relative;\n  background: #fff;\n  z-index: 2;\n}\n\n.article_body p {\n  margin: 0;\n  margin-bottom: 16px;\n}\n\n.article_body li {\n  margin-bottom: 10px;\n}\n\n\n* {\n  -webkit-tap-highlight-color: transparent;\n}\n\n.header_tab {\n  width: 25%;\n  _border-bottom: #2595dc 5px solid;\n  border-bottom: #2595dc 5px solid;\n  color: #fff;\n  cursor: pointer;\n}\n\n.header_tab_active {\n  /* border-bottom: #0b4c92 5px solid; */\n  border-bottom: #333 5px solid;\n}\n\n.header_app_btn:active {\n  background: #2e9fe6;\n}\n\n.spots_a a:active {\n  background-color: #fafdff;\n}\n\n.day_3slots:active .chart {\n  /* background-color: #f8f8f8; */\n  opacity: .85;\n}\n\n\n.spot_info {\n  width: 50%;\n  padding: 10px;\n  margin-bottom: 20px;\n}\n\n.spot_info .caption {\n  font-size: 12px;\n  color: #aaa;\n  width: 100%;\n}\n\n.spot_info .value {\n  font-size: 17px;\n  color: #0b4c92;\n  width: 100%;\n}\n\n.rating0 {\n  width: 33%;\n  border-left: 5px solid #fff;\n  height: 5px;\n  background: #ddd;\n  margin-top: 10px;\n}\n\n.rating1 {\n  width: 33%;\n  border-left: 5px solid #fff;\n  height: 5px;\n  background: #2595dc;\n  margin-top: 10px;\n\n}\n\n\n\n\n\n\n.half-circle {\n  width: 20px;\n  height: 10px;\n  background-color: none;\n  border-top-left-radius: 110px;\n  border-top-right-radius: 110px;\n  border: 5px solid #fff;\n  border-bottom: 0;\n}\n\n\n.radar_hour {\n  text-align: center;\n  font-size: 15px;\n  line-height: 30px;\n  color: #000;\n  border: 1px solid #ddd;\n}\n\n.radar_hour_active {\n  transition-timing-function: ease-in;\n  transition: 0.4s;\n  font-weight: bold;\n\n  color: #fff;\n  background-color: #2595dc;\n}\n\n/* .radar_hour_active { font-weight: bold; color: #2595dc;  } */\n\n\n\n\n\n\n\n\n\n\n\n\n\n.day .have_waves {\n  text-decoration: none;\n  background: #00a3f4;\n  border: 1px solid #85c9ec;\n  border-radius: 10px;\n  color: #ffffff;\n  margin-right: 10px;\n  font-size: 12px;\n  padding: 5px 10px;\n  margin-top: -2px;\n  line-height: 14px;\n}\n\n.mid {\n  float: none;\n  width: 100%;\n  max-width: 980px !important;\n  margin: 0px auto;\n}\n\n.hp_select {\n  direction: rtl;\n}\n\n.hp_select option {\n  direction: rtl;\n}\n\n.desktop_grid_right {\n}\n\n.desktop_grid_left {\n}\n\n.textfield {\n  background: #fff;\n  border: 1px solid #ddd;\n  border-radius: 10px;\n  padding: 7px 15px;\n  font-size: 14px;\n  color: #333;\n  width: 100%